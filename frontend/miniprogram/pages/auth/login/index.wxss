/* ========== 登录页：国风非遗主题（黑塔保留） ========== */

.login-wrap {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

/* ===== 背景层：水墨国风渐变 ===== */
.login-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
}

/* 水墨晕染基底 */
.bg-ink-wash {
  width: 100%;
  height: 100%;
  background:
    radial-gradient(ellipse 120% 80% at 50% -10%, rgba(139,69,19,0.35) 0%, transparent 60%),
    radial-gradient(ellipse 100% 60% at 20% 90%, rgba(128,0,32,0.25) 0%, transparent 55%),
    radial-gradient(ellipse 80% 70% at 85% 70%, rgba(184,134,11,0.18) 0%, transparent 55%),
    linear-gradient(175deg,
      #1a0f07   0%,
      #2d1810   15%,
      #4a2816   30%,
      #5c3018   48%,
      #6b3a14   65%,
      #7a4012   82%,
      #8b4513   95%,
      #9c4e15   100%
    );
}

/* 暖光斑（朱砂/琥珀色调） */
.bg-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(90rpx);
}
.glow-a {
  width: 480rpx; height: 480rpx;
  left: -120rpx; top: -60rpx;
  background: rgba(200,80,40,0.22);
}
.glow-b {
  width: 380rpx; height: 380rpx;
  right: -60rpx; bottom: 15%;
  background: rgba(218,165,32,0.16);
}

/* 祥云浮动装饰 */
.xiangyun-container { position: fixed; inset: 0; z-index: 1; pointer-events: none; }
.xiangyun {
  position: absolute; font-size: 22rpx; opacity: .12; color: #d4a574;
}
.xy1 { left: 8%;  top: 10%; animation: xyDrift1 7s ease-in-out infinite; }
.xy2 { right: 6%; top: 18%; font-size: 26rpx; opacity: .08; color: #c9965a; animation: xyDrift2 9s ease-in-out infinite; }
.xy3 { left: 62%; top: 38%; animation: xyDrift3 8s ease-in-out infinite reverse; }
.xy4 { right: 12%; bottom: 30%; font-size: 18rpx; opacity: .18; color: #e8c88b; animation: xyDrift1 10s ease-in-out infinite reverse; }
.xy5 { left: 16%; bottom: 12%; animation: xyDrift2 11s ease-in-out infinite; }

@keyframes xyDrift1 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-20rpx)} }
@keyframes xyDrift2 { 0%,100%{transform:translateY(0) rotate(0deg)} 50%{transform:translateY(-14rpx) rotate(6deg)} }
@keyframes xyDrift3 { 0%,100%{transform:translateX(0)} 50%{transform:translateX(18rpx)} }

/* 回纹边饰 */
.huifen-border {
  position: absolute;
  left: 24rpx; right: 24rpx;
  height: 4rpx;
  opacity: .25;
}
.top-huifen {
  top: calc(env(safe-area-inset-top) + 16rpx);
  background: repeating-linear-gradient(
    to right,
    transparent, transparent 8rpx,
    rgba(212,165,116,.5) 8rpx, rgba(212,165,116,.5) 16rpx,
    transparent 16rpx, transparent 24rpx
  );
}
.bottom-huifen {
  bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  background: repeating-linear-gradient(
    to right,
    transparent, transparent 8rpx,
    rgba(212,165,116,.4) 8rpx, rgba(212,165,116,.4) 16rpx,
    transparent 16rpx, transparent 24rpx
  );
}

/* ===== 主内容区 ===== */
.login-body {
  position: relative;
  z-index: 2;
  padding-top: 72rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  box-sizing: border-box;
}

/* ===== 黑塔形象区（保持核心不变，调整光圈为国风色）===== */
.hero-section {
  position: relative;
  display: flex;
  justify-content: center;
  margin-bottom: 28rpx;
  margin-top: 12rpx;
}

.hero-model-wrap {
  width: 260rpx;
  height: 360rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  transform: scale(1.08);
  position: relative;
  z-index: 3;
}

/* 国风圆环：金线+微光 */
.hero-ring {
  position: absolute;
  left: 50%; top: 50%;
  width: 300rpx; height: 300rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(212,175,86,0.28);
  transform: translate(-50%, -50%);
  animation: ringRotate 18s linear infinite;
  box-shadow: 0 0 20rpx rgba(212,175,86,0.06), inset 0 0 20rpx rgba(212,175,86,0.04);
}
.ring-inner {
  width: 260rpx; height: 260rpx;
  border-color: rgba(212,175,86,0.15);
  animation-duration: 24s;
  animation-direction: reverse;
  box-shadow: none;
}

.ring-spark {
  position: absolute;
  color: #e8c96a;
  font-size: 20rpx;
  text-shadow: 0 0 12rpx rgba(232,201,106,0.7);
}
.rs1 { left: -8rpx;  top: 28%; animation: sparkPulse 2s ease-in-out infinite; }
.rs2 { right: 2rpx; top: 8%;  animation: sparkPulse 3s ease-in-out infinite 0.6s; }
.rs3 { right: -12rpx; bottom: 32%; animation: sparkPulse 2.5s ease-in-out infinite 1.2s; }
.rs4 { left: 4rpx;   bottom: 8%; animation: sparkPulse 2.8s ease-in-out infinite 0.3s; }

@keyframes ringRotate { to { transform: translate(-50%, -50%) rotate(360deg); } }
@keyframes sparkPulse { 0%,100%{opacity:.4} 50%{opacity:1;text-shadow:0 0 18rpx rgba(232,201,106,1)} }

/* ===== 品牌文案区 ===== */
.brand-section {
  text-align: center;
  padding: 0 36rpx;
  margin-bottom: 40rpx;
}

/* 印章式徽章：朱红底白字 */
.yin-badge {
  display: inline-block;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #fff;
  padding: 8rpx 26rpx;
  border-radius: 4rpx;
  background: linear-gradient(135deg, #b22222, #cd3333);
  border: 1rpx solid rgba(255,255,255,0.15);
  box-shadow: 0 4rpx 16rpx rgba(178,34,34,0.35);
  margin-bottom: 24rpx;
  font-weight: 500;
}

/* 标题行：带书名号 */
.brand-title-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.title-deco {
  font-size: 30rpx;
  color: rgba(212,175,86,0.5);
  font-weight: 300;
}

.brand-title {
  font-size: 42rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 5rpx;
  text-shadow:
    0 2rpx 4rpx rgba(0,0,0,0.3),
    0 0 30rpx rgba(212,175,86,0.15);
}

.brand-subtitle {
  font-size: 26rpx;
  color: #d4b896;
  letter-spacing: 3rpx;
  margin-bottom: 32rpx;
  font-weight: 400;
}

/* ===== 三大亮点：书签卷轴式卡片（无图标，纯文字+色带） ===== */
.features-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.feat-card {
  flex: 1;
  max-width: 200rpx;
  position: relative;
  padding: 28rpx 14rpx 20rpx;
  border-radius: 12rpx;
  background: rgba(0,0,0,0.18);
  border-left: 4rpx solid;
  text-align: center;
  overflow: hidden;
}
.feat-ai { border-left-color: #8b5cf6; }
.feat-rec { border-left-color: #ef4444; }
.feat-kb { border-left-color: #f59e0b; }

/* 左侧竖条装饰 */
.feat-ribbon {
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 4rpx; opacity: .5;
}
.feat-ai .feat-ribbon { background: linear-gradient(180deg, transparent, #a78bfa, transparent); }
.feat-rec .feat-ribbon { background: linear-gradient(180deg, transparent, #fca5a5, transparent); }
.feat-kb .feat-ribbon { background: linear-gradient(180deg, transparent, #fcd34d, transparent); }

/* 中文数字序号 */
.feat-num {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  margin-bottom: 12rpx;
  opacity: .6;
  font-family: "STKaiti", "KaiTi", serif;
}
.feat-ai .feat-num { color: #c4b5fd; }
.feat-rec .feat-num { color: #fecaac; }
.feat-kb .feat-num { color: #fde68a; }

.feat-name {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  margin-bottom: 10rpx;
  line-height: 1.35;
}
.feat-ai .feat-name { color: #e0d4ff; }
.feat-rec .feat-name { color: #fecaca; }
.feat-kb .feat-name { color: #fef3c7; }

.feat-desc {
  display: block;
  font-size: 22rpx;
  opacity: .5;
  line-height: 1.5;
  letter-spacing: 1rpx;
}

.feat-name {
  font-size: 23rpx;
  font-weight: 700;
  color: #f0dcc0;
  letter-spacing: 1rpx;
}

.feat-desc {
  font-size: 18rpx;
  color: #a88868;
  line-height: 1.4;
  text-align: center;
}

/* ===== 登录表单 ===== */
.form-section {
  width: 90%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: auto;
}

.input-wrap {
  position: relative;
}

.nickname-input {
  height: 88rpx;
  border-radius: 44rpx;
  background: rgba(255,250,240,0.07);
  border: 1rpx solid rgba(212,175,86,0.22);
  padding: 0 34rpx;
  font-size: 28rpx;
  color: #fff;
  box-sizing: border-box;
  transition: border-color .25s ease;
}

.ph-text {
  color: #9a7e58;
  font-size: 26rpx;
}

/* ===== 国风登录按钮（纯文字，不用嵌套view） ===== */
.guofeng-login-btn {
  height: 92rpx !important;
  border-radius: 46rpx !important;
  /* 朱砂→金渐变 */
  background: linear-gradient(135deg, #a52a2a 0%, #b22222 30%, #c93c3c 60%, #d4af37 100%) !important;
  color: #fff !important;
  font-size: 30rpx !important;
  font-weight: 700 !important;
  line-height: 92rpx !important;
  letter-spacing: 4rpx;
  border: 1rpx solid rgba(212,175,86,0.35) !important;
  box-shadow:
    0 8rpx 28rpx rgba(165,42,42,0.45),
    0 2rpx 8rpx rgba(212,175,55,0.25),
    inset 0 1rpx 0 rgba(255,255,255,0.18);
  transition: all .2s ease;
  padding: 0 48rpx !important;
}

.guofeng-login-btn::after {
  display: none !important;
}

.agreement-line {
  text-align: center;
  margin-top: -8rpx;
}

.agreement-line text {
  font-size: 21rpx;
  color: #8a7358;
}

.link-text {
  color: #d4a574;
  text-decoration: underline;
}

/* 底部Slogan */
.footer-slogan {
  padding: 36rpx 0 56rpx;
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4rpx;
}

.slogan-left, .slogan-right {
  font-size: 24rpx;
  color: rgba(212,175,116,0.5);
  letter-spacing: 2rpx;
  font-family: "STKaiti", "KaiTi", serif;
}
.slogan-dot {
  font-size: 24rpx;
  color: rgba(212,175,116,0.3);
}
