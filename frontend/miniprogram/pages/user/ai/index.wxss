/* UI优化：ASK主区域显性化 */
.ask-clarify-card {
  background: linear-gradient(180deg, rgba(255, 248, 238, 0.98), rgba(253, 241, 221, 0.96));
  border: 1rpx solid rgba(221, 187, 138, 0.28);
  animation: askCardFadeIn 0.4s ease-out;
}

@keyframes askCardFadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.ask-clarify-title {
  font-size: 27rpx;
  font-weight: 800;
  color: #7f4d21;
}

.ask-clarify-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.ask-clarify-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f3d2a1, #e8b960);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.ask-clarify-body {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.76;
  color: #6c4a2f;
}

.ask-clarify-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.ask-clarify-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 62rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 252, 247, 0.88);
  border: 1rpx solid rgba(221, 187, 138, 0.26);
  color: #8c5b32;
  font-size: 23rpx;
  transition: all 0.2s ease;
}

.ask-clarify-chip:active {
  transform: scale(0.95);
  opacity: 0.85;
}

.ask-clarify-chip.active {
  background: linear-gradient(135deg, #f3d2a1, #efbb76);
  color: #5f2f10;
  border-color: transparent;
  animation: chipSelect 0.3s ease;
}

@keyframes chipSelect {
  0% { transform: scale(1); }
  50% { transform: scale(1.08); }
  100% { transform: scale(1); }
}

