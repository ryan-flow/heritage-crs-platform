}

.crs-bottom-progress {
  flex: 1;
  height: 6rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  overflow: hidden;
}

.crs-bottom-fill {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}

.crs-bottom-pct {
