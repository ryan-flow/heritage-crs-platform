/* ═══════════════════════════════════════════════
   CRS v2.0.7 模式升级庆祝动效
   ═══════════════════════════════════════════════ */

.mode-celebration {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(62, 39, 20, 0.72);
  backdrop-filter: blur(8px);
  opacity: 0;
  animation: celebrationFadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  pointer-events: none;
}

.mode-celebration.active {
  pointer-events: auto;
}

.mode-celebration.fading {
  animation: celebrationFadeOut 0.35s cubic-bezier(0.4, 0, 1, 1) forwards;
}

@keyframes celebrationFadeIn {
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes celebrationFadeOut {
  0% { opacity: 1; }
  100% { opacity: 0; }
}

.celebration-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: celebrationScaleIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

/* 模式升级光晕环 */
.celebration-content::before {
  content: '';
  position: absolute;
  width: 420rpx;
  height: 420rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(217, 171, 83, 0.3);
  animation: celebrationRing 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  pointer-events: none;
}

@keyframes celebrationRing {
  0% { transform: scale(0.3); opacity: 0; }
  40% { opacity: 0.8; }
  100% { transform: scale(1.6); opacity: 0; }
}

@keyframes celebrationScaleIn {
  0% { opacity: 0; transform: scale(0.5); }
  100% { opacity: 1; transform: scale(1); }
}

.celebration-icon {
  font-size: 96rpx;
  margin-bottom: 20rpx;
  animation: celebrationIconBounce 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
}

@keyframes celebrationIconBounce {
  0% { transform: scale(0) rotate(-30deg); }
  60% { transform: scale(1.2) rotate(5deg); }
  100% { transform: scale(1) rotate(0deg); }
}

.celebration-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #fffaf3;
  text-shadow: 0 4rpx 16rpx rgba(159, 45, 34, 0.4);
  margin-bottom: 16rpx;
}

.celebration-mode {
  font-size: 52rpx;
  font-weight: 900;
  padding: 12rpx 40rpx;
  border-radius: 999rpx;
  color: #fff;
  margin-bottom: 20rpx;
}

/* 模式badge颜色 + 对应glow */
.celebration-mode.crs-mode-cold_start {
  background: linear-gradient(135deg, #ff9800, #ffb74d);
  box-shadow: 0 0 40rpx rgba(255, 152, 0, 0.5);
  animation: glowWarm 1.2s ease-in-out infinite alternate;
}

.celebration-mode.crs-mode-mixed {
  background: linear-gradient(135deg, #2196f3, #64b5f6);
  box-shadow: 0 0 40rpx rgba(33, 150, 243, 0.5);
  animation: glowBlue 1.2s ease-in-out infinite alternate;
}

.celebration-mode.crs-mode-precision {
  background: linear-gradient(135deg, #4caf50, #81c784);
  box-shadow: 0 0 40rpx rgba(76, 175, 80, 0.5);
  animation: glowGreen 1.2s ease-in-out infinite alternate;
}

@keyframes glowWarm {
  0% { box-shadow: 0 0 20rpx rgba(255, 152, 0, 0.3); }
  100% { box-shadow: 0 0 60rpx rgba(255, 152, 0, 0.6); }
}

@keyframes glowBlue {
  0% { box-shadow: 0 0 20rpx rgba(33, 150, 243, 0.3); }
  100% { box-shadow: 0 0 60rpx rgba(33, 150, 243, 0.6); }
}

@keyframes glowGreen {
  0% { box-shadow: 0 0 20rpx rgba(76, 175, 80, 0.3); }
  100% { box-shadow: 0 0 60rpx rgba(76, 175, 80, 0.6); }
}

.celebration-desc {
  font-size: 26rpx;
  color: rgba(255, 250, 243, 0.85);
  text-align: center;
  line-height: 1.6;
}

/* 粒子效果 */
.celebration-particles {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  z-index: 1;
}

.particle {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  animation: particleBurst 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  opacity: 0;
}

.particle.p1  { background: #ff9800; animation-delay: 0.05s; }
.particle.p2  { background: #9f2d22; animation-delay: 0.1s; }
.particle.p3  { background: #d9ab53; animation-delay: 0.15s; }
.particle.p4  { background: #2196f3; animation-delay: 0.2s; }
.particle.p5  { background: #4caf50; animation-delay: 0.25s; }
.particle.p6  { background: #ffb74d; animation-delay: 0.1s; }
.particle.p7  { background: #c65b43; animation-delay: 0.15s; }
.particle.p8  { background: #64b5f6; animation-delay: 0.2s; }
.particle.p9  { background: #81c784; animation-delay: 0.25s; }
.particle.p10 { background: #ba7f34; animation-delay: 0.3s; }
.particle.p11 { background: #f4e4d0; animation-delay: 0.35s; }
.particle.p12 { background: #9f2d22; animation-delay: 0.4s; }

@keyframes particleBurst {
  0% {
    opacity: 1;
    transform: translate(0, 0) scale(1);
  }
  80% {
    opacity: 0.8;
  }
  100% {
    opacity: 0;
    transform: translate(var(--px), var(--py)) scale(0.3);
  }
}

/* 12个粒子方向预设 */
.p1  { --px: -200rpx; --py: -280rpx; }
.p2  { --px: 0rpx;    --py: -320rpx; }
.p3  { --px: 200rpx;  --py: -280rpx; }
.p4  { --px: 280rpx;  --py: -120rpx; }
.p5  { --px: 300rpx;  --py: 80rpx;   }
.p6  { --px: 180rpx;  --py: 240rpx;  }
.p7  { --px: -180rpx; --py: 240rpx;  }
.p8  { --px: -300rpx; --py: 80rpx;   }
.p9  { --px: -280rpx; --py: -120rpx; }
.p10 { --px: 60rpx;   --py: 200rpx;  }
.p11 { --px: -60rpx;  --py: 200rpx;  }
.p12 { --px: 0rpx;    --py: -180rpx; }

/* 推荐满意度反馈条 */
.recommend-feedback-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 18rpx;
