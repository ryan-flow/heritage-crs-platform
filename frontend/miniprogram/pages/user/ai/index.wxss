  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 2rpx;
}

.summary-pill {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 249, 241, 0.86);
  border: 1rpx solid rgba(220, 196, 166, 0.34);
