}

.layer-divider-label {
  font-size: 22rpx;
  color: #9a7b5d;
  font-weight: 700;
  white-space: nowrap;
}

/* L2 推荐卡片操作行整合 */
.recommend-detail-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 8rpx;
  align-items: center;
}

.recommend-detail-actions .recommend-explain-toggle,
.recommend-detail-actions .recommend-explain-copy,
.recommend-detail-actions .recommend-open-combo {
  margin-top: 0;
  font-size: 21rpx;
}

/* L3 深入细节卡片降权 */
.layer-detail-card {
  background: rgba(255, 252, 247, 0.7) !important;
  box-shadow: none !important;
  border-color: rgba(227, 199, 166, 0.12) !important;
}

/* ═══════════════════════════════════════════════
   P0-2 运营数据面板
   ═══════════════════════════════════════════════ */

.ops-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ops-toggle-icon {
  font-size: 20rpx;
  color: #9a7b5d;
}

.ops-grid {
  display: flex;
  gap: 24rpx;
  margin-top: 20rpx;
}

.ops-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.ops-ring-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}

.ops-ring {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  transition: background 0.6s ease;
}

.ops-ring-inner {
  position: absolute;
  inset: 14rpx;
  border-radius: 50%;
  background: rgba(255, 252, 247, 0.95);
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.ops-ring-val {
  font-size: 32rpx;
  font-weight: 900;
  color: #3f2c1d;
}

.ops-ring-unit {
  font-size: 18rpx;
  color: #9a7b5d;
  margin-left: 2rpx;
}

.ops-item-label {
  font-size: 21rpx;
  color: #8a6a4b;
  font-weight: 600;
}

.ops-metrics {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.ops-metric {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14rpx 0;
  border-radius: 14rpx;
  background: rgba(255, 248, 236, 0.6);
}

.ops-metric-val {
  font-size: 30rpx;
  font-weight: 900;
  color: #3f2c1d;
}

.ops-metric-label {
  font-size: 19rpx;
  color: #9a7b5d;
  margin-top: 4rpx;
}
