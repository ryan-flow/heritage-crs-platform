  0% { opacity: 0; transform: translateY(10rpx); }
  100% { opacity: 1; transform: translateY(0); }
}

/* ═══════════════════════════════════════════════
   CRS v2.0 置信度面板样式
   ═══════════════════════════════════════════════ */

.crs-state-card {
  background: linear-gradient(180deg, rgba(252, 245, 232, 0.98), rgba(249, 238, 218, 0.96));
