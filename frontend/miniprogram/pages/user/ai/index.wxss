/* UI优化：AI页局部变量 */
.ai-page {
  --ai-page-bg: #fbf4ea;
  --ai-panel-soft: rgba(255, 250, 242, 0.92);
  --ai-text-weak: #9c846d;
  --ai-text-muted: #a08a75;
  --ai-line-soft: rgba(205, 180, 144, 0.28);
  --ai-chip-bg: rgba(255, 245, 232, 0.92);
  --ai-gold: #d7a445;
  --ai-chip-max-width: 420rpx;
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at 14% 10%, rgba(255, 220, 172, 0.34), transparent 28%),
    radial-gradient(circle at 86% 12%, rgba(169, 149, 255, 0.17), transparent 24%),
    linear-gradient(180deg, #fbf4ea 0%, #f5ebdc 52%, #ecdeca 100%);
  padding-bottom: 56rpx;
}

.ai-aurora {
  position: absolute;
  border-radius: 50%;
  filter: blur(20rpx);
  pointer-events: none;
}

.ai-aurora-left {
  width: 280rpx;
  height: 280rpx;
  left: -88rpx;
  top: 120rpx;
  background: rgba(255, 201, 135, 0.22);
}

.ai-aurora-right {
  width: 340rpx;
  height: 340rpx;
  right: -120rpx;
  top: 320rpx;
  background: rgba(142, 122, 240, 0.13);
}

/* UI优化：压缩 Hero 区域高度 */
.ai-top-stage {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: 38rpx;
  padding: 18rpx 22rpx 14rpx;
  margin-bottom: 16rpx;
  background:
    radial-gradient(circle at 50% 18%, rgba(255, 213, 164, 0.12), transparent 24%),
    linear-gradient(135deg, var(--banner-ai-start) 0%, var(--banner-ai-end) 100%);
  box-shadow: 0 18rpx 42rpx rgba(70, 35, 49, 0.18);
  border: 1rpx solid rgba(255, 238, 220, 0.08);
}

.stage-copy.centered,
.avatar-float-wrap.centered,
.stage-actions.centered {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.stage-copy.centered {
  gap: 8rpx;
}

.stage-badge {
  margin-bottom: 6rpx;
}

/* UI优化：Hero 顶部弱化清空入口 */
.clear-chat-btn {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  z-index: 2;
  font-size: 24rpx;
  line-height: 1;
  color: rgba(255, 241, 226, 0.62);
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 237, 0.08);
}

.ai-top-stage::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 38rpx;
  background:
    radial-gradient(circle at 20% 12%, rgba(255, 255, 255, 0.10), transparent 32%),
    radial-gradient(circle at 78% 16%, rgba(167, 129, 255, 0.18), transparent 30%);
  pointer-events: none;
}

.ai-top-stage::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 226rpx;
  width: 420rpx;
  height: 220rpx;
  transform: translateX(-50%);
  background: radial-gradient(circle, rgba(170, 120, 255, 0.20), rgba(170, 120, 255, 0.02) 70%, transparent 76%);
  filter: blur(6rpx);
  pointer-events: none;
}

.stage-copy.centered,
.avatar-float-wrap.centered,
.stage-actions.centered {
  position: relative;
  z-index: 1;
}

.stage-title {
  font-size: 54rpx;
  line-height: 1.06;
  letter-spacing: 1rpx;
}

/* UI优化：副标题降权 */
.stage-sub {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: rgba(255, 241, 226, 0.66);
}

.stage-desc.compact {
  color: rgba(255, 243, 231, 0.82);
}

/* UI优化：压缩数字人展示区 */
.avatar-float-wrap.centered {
