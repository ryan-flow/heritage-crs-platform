  box-shadow: 0 4rpx 12rpx rgba(33, 150, 243, 0.25);
}

.crs-mode-badge.crs-mode-precision {
  background: linear-gradient(135deg, #4caf50, #81c784);
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.25);
}

.crs-confidence-text {
  font-size: 22rpx;
  color: #8a6a4b;
  font-weight: 600;
}

.crs-confidence-bar {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(220, 200, 170, 0.35);
  overflow: hidden;
  margin-bottom: 14rpx;
}

.crs-confidence-fill {
  height: 100%;
  border-radius: 999rpx;
