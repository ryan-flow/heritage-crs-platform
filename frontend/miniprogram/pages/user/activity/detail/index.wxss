.detail-page {
  padding-bottom: 40rpx;
}

.detail-hero {
  overflow: hidden;
  background: linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(249, 239, 225, 0.98));
}

.cover {
  height: 320rpx;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 22rpx;
  position: relative;
}

.cover-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(18, 10, 8, 0.08), rgba(22, 10, 8, 0.62));
}

.cover-overlay-title {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 18rpx;
  color: #fff6ee;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-fallback {
  background: linear-gradient(135deg, #9f2d22, #d79c53);
  color: #fff7ef;
  padding: 28rpx;
  box-sizing: border-box;
}

.cover-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 22rpx;
  margin-bottom: 16rpx;
}

.cover-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.4;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
  color: #2f2318;
}

.status-chip {
  display: inline-flex;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #f7e7dc;
  color: #9f2d22;
  font-size: 22rpx;
}

.hero-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.hero-meta-chip {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #f3e6d6;
  color: #8b6139;
  font-size: 21rpx;
}

.info-card {
  gap: 14rpx;
  background: linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(249, 239, 225, 0.98));
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(143, 108, 73, 0.12);
}

.info-row:last-child {
  border-bottom: 0;
}

.progress-wrap {
  margin-top: 12rpx;
}

.progress-track {
  height: 14rpx;
  border-radius: 999rpx;
  background: #f1e4d4;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(135deg, #9f2d22, #d79c53);
}

.progress-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7f5f3f;
}

.status-flow {
  margin-top: 14rpx;
}

.flow-title {
  font-size: 24rpx;
  color: #6f5337;
  margin-bottom: 8rpx;
}

.flow-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.flow-pill {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #efe2d2;
  color: #8b5c2f;
}

.flow-pill.active {
  background: #9f2d22;
  color: #fff;
}

.info-label {
  color: #8a6640;
  font-size: 25rpx;
}

.info-value {
  flex: 1;
  text-align: right;
  color: #3f2c1d;
  font-size: 26rpx;
  line-height: 1.7;
}

.desc {
  color: #624a35;
  line-height: 1.9;
  white-space: pre-wrap;
  font-size: 27rpx;
}

.bullet-item {
  color: #624a35;
  line-height: 1.85;
  font-size: 26rpx;
  margin-bottom: 10rpx;
}

.tips-wrap {
  margin-top: 14rpx;
}

.tips-item {
  margin-bottom: 8rpx;
  color: #866445;
  font-size: 24rpx;
}

.register-btn {
  background: linear-gradient(135deg, #9f2d22, #c04833);
  color: #fff;
  border-radius: 999rpx;
  margin-top: 10rpx;
}

.cancel-btn {
  background: linear-gradient(135deg, #7f6a52, #9e8469);
  color: #fff;
  border-radius: 999rpx;
  margin-top: 10rpx;
}

.empty {
  color: #9f8b72;
  text-align: center;
  padding: 40rpx 0;
}
