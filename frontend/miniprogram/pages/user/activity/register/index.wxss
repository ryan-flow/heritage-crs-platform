.register-page {
  padding-bottom: 40rpx;
}

.register-hero {
  background: linear-gradient(135deg, #24140f 0%, #6d2d22 52%, #c68149 100%);
  color: #fff8ef;
  margin-bottom: 20rpx;
}

.hero-kicker {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 245, 230, 0.14);
  color: #ffe1bc;
  font-size: 22rpx;
  margin-bottom: 14rpx;
}

.hero-title {
  color: #fff8ef;
  margin-bottom: 12rpx;
}

.hero-subtitle {
  color: rgba(255, 244, 232, 0.9);
}

.register-card {
  background: linear-gradient(180deg, rgba(255, 251, 245, 0.98), rgba(251, 242, 230, 0.96));
}

.fx-success {
  animation: successPulse .7s ease;
}

@keyframes successPulse {
  0% { transform: scale(1); box-shadow: 0 0 0 rgba(74, 172, 120, 0); }
  50% { transform: scale(1.02); box-shadow: 0 0 0 16rpx rgba(74, 172, 120, .12); }
  100% { transform: scale(1); box-shadow: 0 0 0 rgba(74, 172, 120, 0); }
}

.label {
  margin-bottom: 14rpx;
  color: #775a3f;
  font-size: 26rpx;
}

.textarea {
  width: 100%;
  min-height: 220rpx;
  background: #fffdf9;
  border: 1rpx solid #eadac7;
  border-radius: 18rpx;
  padding: 18rpx;
  box-sizing: border-box;
  margin-bottom: 18rpx;
  color: #4e3928;
}

.notice-box {
  margin-bottom: 18rpx;
  border: 1rpx solid #ecd8c1;
  border-radius: 14rpx;
  padding: 14rpx;
  background: #fff8ef;
}

.notice-check {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  font-size: 24rpx;
  color: #6f5438;
  line-height: 1.7;
}

.btn {
  background: linear-gradient(135deg, #9f2d22, #c04833);
  color: #fff;
  border-radius: 999rpx;
}
