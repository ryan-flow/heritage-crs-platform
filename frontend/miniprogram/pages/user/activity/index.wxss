.activity-page { padding-bottom: 40rpx; }

/* UI优化：活动页 Banner 色彩统一 */
.activity-hero {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, var(--banner-interact-start) 0%, var(--banner-interact-end) 100%);
  color: #fff7ef;
  margin-bottom: 14rpx;
}

.hero-kicker { display:inline-block; padding:8rpx 18rpx; border-radius:999rpx; background:rgba(255,245,230,.14); color:#ffe1bc; font-size:22rpx; margin-bottom:12rpx; }
.hero-title { color:#fff8f0; margin-bottom:10rpx; }
.hero-subtitle { color:rgba(255,242,230,.9); }
.hero-tip { margin-top: 12rpx; font-size: 22rpx; color: rgba(255, 237, 212, 0.9); }

/* UI优化：月份标签横向滚动容器 */
.month-scroll {
  white-space: nowrap;
  margin-bottom: 12rpx;
  padding-bottom: 6rpx;
}

.month-pill {
  display:inline-flex;
  margin-right:10rpx;
  padding:10rpx 20rpx;
  border-radius:999rpx;
  background:#f2e3d0;
  color:#8a5a2b;
  font-size:22rpx;
}

.month-pill.active {
  background:#9f2d22;
  color:#fff;
}

.activity-highlight,
.activity-card { background: linear-gradient(180deg, rgba(255,252,247,.98), rgba(249,239,225,.98)); }

.recommend-inline-title { font-size:30rpx; font-weight:700; color:#3a2619; margin-bottom:10rpx; }
.recommend-inline {
  padding-top: 18rpx;
}

/* UI优化：活动页推荐说明去重 */
.recommend-guide {
  display: none;
}

.recommend-inline-item { display:flex; justify-content:space-between; gap:14rpx; padding:16rpx 0; border-top:1rpx solid rgba(143,108,73,.12); }
.recommend-inline-cover { width: 120rpx; height: 80rpx; border-radius: 12rpx; flex-shrink: 0; }
.recommend-inline-cover-fallback { display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg,#b88458,#d5ab82); color:#fff7ef; font-size:20rpx; }
.recommend-inline-name { font-size:27rpx; font-weight:700; color:#3d2719; }
.recommend-inline-note { font-size:23rpx; color:#84674c; line-height:1.7; }
.recommend-reason { margin-top:6rpx; font-size:21rpx; color:#9a744f; }
.recommend-inline-arrow { font-size:36rpx; color:#a8713c; }

.event-cover-wrap { position: relative; margin-bottom: 16rpx; border-radius: 20rpx; overflow: hidden; }
.event-cover { width: 100%; height: 380rpx; display: block; }
.event-badge { position: absolute; left: 16rpx; top: 16rpx; padding: 6rpx 14rpx; border-radius: 999rpx; background: rgba(50, 28, 20, 0.66); color: #fff1de; font-size: 21rpx; }
.title { font-size: 32rpx; font-weight: 800; flex: 1; color: #342519; }
.row-top { display:flex; align-items:center; gap:12rpx; margin-bottom:10rpx; }
.status { flex-shrink:0; padding:6rpx 14rpx; border-radius:999rpx; font-size:22rpx; }
.status.is-open { color:#8d2b21; background:#f8e4db; }
.status.is-closed { color:#6e5a46; background:#efe5d9; }
.meta-row { display: flex; flex-wrap: wrap; gap: 10rpx; margin-bottom: 10rpx; }
.meta-chip { padding: 6rpx 12rpx; border-radius: 999rpx; background: #f3e6d6; color: #8a6545; font-size: 21rpx; }
.desc { color:#73583d; font-size:25rpx; line-height:1.7; }

.mini-register { margin-top: 12rpx; border-radius: 999rpx; }

.fx-pulse { animation: pulseCard .9s ease; }
@keyframes pulseCard { 0% { transform: scale(1); box-shadow: 0 0 0 rgba(159,45,34,0); } 50% { transform: scale(1.02); box-shadow: 0 0 0 16rpx rgba(159,45,34,.08); } 100% { transform: scale(1); box-shadow: 0 0 0 rgba(159,45,34,0); } }

.skeleton-card { overflow:hidden; }
.skeleton-line { height:22rpx; border-radius:999rpx; margin-bottom:14rpx; background:linear-gradient(90deg,#f3e7d9 25%,#ecdcc9 50%,#f3e7d9 75%); background-size:240% 100%; animation:shimmer 1.4s infinite; }
.w75 { width:75%; } .w60 { width:60%; } .w45 { width:45%; margin-bottom:0; }
@keyframes shimmer { from { background-position:200% 0; } to { background-position:-200% 0; } }

.placeholder-cover {
  display:flex;
  align-items:center;
  justify-content:center;
  color:#f6e8d8;
  font-size:26rpx;
  background:linear-gradient(135deg,#7c3d2d,#c07a49);
}

.clamp-1 { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
