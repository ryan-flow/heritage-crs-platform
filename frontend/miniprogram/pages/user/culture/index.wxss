.culture-page {
  padding-bottom: 40rpx;
}

/* UI优化：文化页 Banner 色彩统一 */
.culture-hero {
  background: linear-gradient(135deg, var(--banner-content-start) 0%, var(--banner-content-end) 100%);
  color: #fff8f0;
  margin-bottom: 20rpx;
}

.hero-kicker {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 245, 230, 0.14);
  color: #ffe1bc;
  font-size: 22rpx;
  margin-bottom: 14rpx;
}

.hero-title {
  color: #fff8ef;
  margin-bottom: 12rpx;
}

.hero-subtitle {
  color: rgba(255, 244, 232, 0.9);
}

.category-card {
  background: linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(249, 239, 225, 0.98));
  padding-bottom: 10rpx;
}

.category-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2f2419;
  margin-bottom: 10rpx;
}

.category-desc {
  font-size: 25rpx;
  color: #7a6042;
  line-height: 1.8;
  margin-bottom: 18rpx;
}

.heritage-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(143, 108, 73, 0.12);
}

.heritage-name {
  font-size: 29rpx;
  font-weight: 700;
  color: #352416;
  margin-bottom: 6rpx;
}

.heritage-note {
  font-size: 25rpx;
  color: #7d6247;
  line-height: 1.7;
}

.heritage-arrow {
  font-size: 36rpx;
  color: #a8713c;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(140, 106, 66, 0.08), rgba(159, 45, 34, 0.06));
  border: 2rpx solid rgba(140, 106, 66, 0.1);
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9f8b72;
  font-weight: 600;
}

.empty-hint {
  font-size: 22rpx;
  color: #bba688;
  margin-top: 6rpx;
}
