<view class="container culture-page">
  <view class="culture-hero card">
    <view class="hero-kicker">分类导览</view>
    <view class="page-title hero-title">非遗文化分类</view>
    <view class="page-subtitle hero-subtitle">已扩展为大规模专题库，按主题分组浏览，快速完成从入门到深读。</view>
  </view>

  <view wx:if="{{loading}}" class="empty">加载中...</view>
  <view wx:elif="{{!list.length}}" class="empty-state">
    <view class="empty-icon-box"></view>
    <view class="empty-text">暂无分类内容</view>
    <view class="empty-hint">请稍后再来查看</view>
  </view>

  <view wx:for="{{list}}" wx:key="id" class="card category-card">
    <view class="category-title">{{item.title}}</view>
    <view wx:for="{{item.items}}" wx:key="id" class="heritage-item" data-id="{{item.id}}" bindtap="toDetail">
      <view>
        <view class="heritage-name">{{item.name}}</view>
        <view class="heritage-note">{{item.note}}</view>
      </view>
      <view class="heritage-arrow">›</view>
    </view>
  </view>
</view>
