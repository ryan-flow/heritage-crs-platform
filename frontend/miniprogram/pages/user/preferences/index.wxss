.pref-page {
  padding-bottom: 60rpx;
}

/* 页面头部 */
.pref-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(159, 45, 34, 0.05), rgba(140, 106, 66, 0.07));
  border: 1rpx solid rgba(159, 45, 34, 0.06);
}

.pref-header-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #9f2d22, #c74a3a);
  flex-shrink: 0;
}

.pref-header-text {
  flex: 1;
  min-width: 0;
}

.pref-header-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #2c1810;
  margin-bottom: 4rpx;
}

.pref-header-desc {
  font-size: 24rpx;
  color: #8a6b4a;
  line-height: 1.5;
}

/* 偏好区块 */
.pref-section {
  margin-bottom: 20rpx;
  padding: 24rpx;
  background: #fffdf9;
  border: 1rpx solid rgba(140, 106, 66, 0.08);
}

.pref-section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

/* 分类圆点 */
.pref-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-heritage { background: #9f2d22; }
.dot-scene { background: #6366f1; }
.dot-region { background: #2d8a4e; }

.pref-section-info {
  flex: 1;
  min-width: 0;
}

.pref-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #3c2618;
  margin-bottom: 2rpx;
}

.pref-section-hint {
  font-size: 22rpx;
  color: #9a744f;
}

/* 标签选项 */
.pref-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.pref-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(140, 106, 66, 0.06);
  color: #6b4f35;
  font-size: 25rpx;
  font-weight: 500;
  border: 2rpx solid rgba(140, 106, 66, 0.12);
  transition: all 0.25s ease;
  user-select: none;
  -webkit-tap-highlight-color: transparent;
}

.pref-chip-hover {
  transform: scale(0.95);
  background: rgba(140, 106, 66, 0.1);
}

/* 点击弹跳 */
.pref-chip.tapped {
  animation: chipTap 0.3s ease;
}

@keyframes chipTap {
  0% { transform: scale(1); }
  25% { transform: scale(0.9); }
  55% { transform: scale(1.05); }
  100% { transform: scale(1); }
}

/* 选中态：中国红渐变 + 光晕（!important确保覆盖） */
.pref-chip.active {
  background: linear-gradient(135deg, #9f2d22, #c74a3a) !important;
  color: #fff !important;
  border-color: rgba(159, 45, 34, 0.2) !important;
  box-shadow: 0 4rpx 16rpx rgba(159, 45, 34, 0.25) !important;
  font-weight: 600 !important;
}

.chip-active-inner {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.chip-check {
  font-size: 24rpx;
  font-weight: 700;
  opacity: 0.9;
}

.pref-chip.active.tapped {
  animation: chipTapActive 0.35s ease;
}

@keyframes chipTapActive {
  0% { transform: scale(1); box-shadow: 0 4rpx 16rpx rgba(159, 45, 34, 0.25); }
  25% { transform: scale(0.9); box-shadow: 0 2rpx 8rpx rgba(159, 45, 34, 0.15); }
  55% { transform: scale(1.05); box-shadow: 0 6rpx 22rpx rgba(159, 45, 34, 0.35); }
  100% { transform: scale(1); box-shadow: 0 4rpx 16rpx rgba(159, 45, 34, 0.25); }
}

/* 保存按钮 */
.pref-btn-wrapper {
  padding: 0 12rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: 6rpx;
  text-align: center;
  border: none;
  transition: all 0.25s ease;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn-ready {
  background: linear-gradient(135deg, #9f2d22, #c74a3a);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(159, 45, 34, 0.3);
}

.save-btn-ready::after {
  border: none;
}

.save-btn-disabled {
  background: #ede5dc;
  color: #b8a89a;
  box-shadow: none;
}

.save-btn-disabled::after {
  border: none;
}

.save-btn[loading] {
  background: linear-gradient(135deg, #bf563f, #d47a65) !important;
  color: rgba(255, 255, 255, 0.8) !important;
}
