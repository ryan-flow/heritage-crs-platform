/* ==============================
   遗产详情页 - 古风配色
   棕金 #8c6a42 | 中国红 #9f2d22 | 宣纸底 #fffcf7 | 紫蓝 #6366f1
   ============================== */

.heritage-detail-page {
  padding-bottom: 60rpx;
  background: #fffcf7;
  min-height: 100vh;
}

/* ---------- 加载状态 ---------- */
.loading-shell {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid rgba(140, 106, 66, 0.2);
  border-top-color: #8c6a42;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #8a7352;
}

/* ---------- 空状态 ---------- */
.empty-shell {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #5b4330;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #a08b70;
}

/* ---------- 封面区 ---------- */
.cover-section {
  position: relative;
  height: 440rpx;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
}

.cover-pattern {
  position: absolute;
  inset: 0;
  opacity: 0.08;
  background-image:
    radial-gradient(circle at 20% 30%, rgba(255,255,255,0.3) 0%, transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(255,255,255,0.2) 0%, transparent 40%);
}

.cover-watermark {
  position: absolute;
  right: 30rpx;
  bottom: 30rpx;
  font-size: 64rpx;
  color: rgba(255, 249, 242, 0.35);
  letter-spacing: 16rpx;
  font-weight: 700;
}

.cover-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    180deg,
    rgba(16, 10, 8, 0.15) 0%,
    rgba(16, 10, 8, 0.02) 40%,
    rgba(16, 10, 8, 0.6) 100%
  );
}

/* ---------- 返回按钮 ---------- */
.cover-back {
  position: absolute;
  top: 60rpx;
  left: 24rpx;
  z-index: 10;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.25);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}

.cover-back:active {
  background: rgba(0, 0, 0, 0.45);
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: 300;
  margin-left: -4rpx;
  margin-top: -2rpx;
}

.cover-info {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 36rpx;
  z-index: 2;
}

.cover-chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 245, 230, 0.22);
  color: #ffe1b7;
  font-size: 22rpx;
  margin-bottom: 16rpx;
  backdrop-filter: blur(4px);
}

.cover-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff8f2;
  line-height: 1.4;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.cover-subtitle {
  font-size: 24rpx;
  color: rgba(255, 242, 231, 0.82);
  line-height: 1.4;
}

/* ---------- 操作栏 ---------- */
.action-bar {
  display: flex;
  gap: 40rpx;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid rgba(140, 106, 66, 0.1);
  background: #fffcf7;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  font-size: 32rpx;
  transition: transform 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon.favorited {
  animation: heartBeat 0.4s ease;
}

.fav-heart {
  transition: transform 0.2s;
}

.favorited-heart {
  animation: heartPop 0.5s ease;
}

@keyframes heartBeat {
  0% { transform: scale(1); }
  30% { transform: scale(1.3); }
  60% { transform: scale(0.95); }
  100% { transform: scale(1); }
}

@keyframes heartPop {
  0% { transform: scale(0.5); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

.fav-loading {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid rgba(140, 106, 66, 0.2);
  border-top-color: #8c6a42;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}

.action-label {
  font-size: 24rpx;
  color: #8a7352;
}

.favorited-label {
  color: #9f2d22;
}

.share-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0;
  margin: 0;
  line-height: 1;
  background: transparent;
  border: none;
  font-size: inherit;
  color: inherit;
}

.share-btn::after {
  border: none;
}

/* ---------- 通用卡片 ---------- */
.card {
  margin: 20rpx 24rpx;
  padding: 28rpx;
  background: linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(249, 239, 225, 0.98));
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(140, 106, 66, 0.06);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #38261a;
}

/* ---------- 基本信息栏 ---------- */
.info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 32rpx;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 45%;
}

.info-label {
  font-size: 24rpx;
  color: #a08b70;
  white-space: nowrap;
}

.info-value {
  font-size: 26rpx;
  color: #5b4330;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

/* ---------- 质量评分条 ---------- */
.score-bar {
  width: 120rpx;
  height: 14rpx;
  background: rgba(140, 106, 66, 0.12);
  border-radius: 7rpx;
  overflow: hidden;
}

.score-fill {
  height: 100%;
  border-radius: 7rpx;
  background: linear-gradient(90deg, #c9a96e, #9f2d22);
  transition: width 0.6s ease;
}

.score-text {
  font-size: 22rpx;
  color: #9f2d22;
  font-weight: 600;
}

/* ---------- 图片画廊 ---------- */
.gallery-section {
  overflow: hidden;
}

.gallery-scroll {
  white-space: nowrap;
  margin: 0 -28rpx;
  padding: 0 28rpx;
}

.gallery-list {
  display: inline-flex;
  gap: 16rpx;
}

.gallery-item {
  display: inline-block;
  width: 280rpx;
  height: 200rpx;
  border-radius: 14rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.gallery-img {
  width: 100%;
  height: 100%;
}

/* ---------- 导览摘要 ---------- */
.intro-text {
  font-size: 28rpx;
  line-height: 1.85;
  color: #5b4330;
}

/* ---------- 核心看点 ---------- */
.highlight-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.highlight-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.highlight-dot {
  width: 12rpx;
  height: 12rpx;
  min-width: 12rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #9f2d22, #d79c53);
  margin-top: 14rpx;
}

.highlight-text {
  font-size: 27rpx;
  line-height: 1.8;
  color: #6b513b;
}

/* ---------- 详细介绍 ---------- */
.body-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.body-paragraph {
  font-size: 28rpx;
  line-height: 2;
  color: #4a3520;
  text-indent: 2em;
}

/* ---------- 展开/收起 ---------- */
.body-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding-top: 24rpx;
  margin-top: 12rpx;
  border-top: 1rpx dashed rgba(140, 106, 66, 0.15);
}

.toggle-text {
  font-size: 26rpx;
  color: #8c6a42;
  font-weight: 500;
}

.toggle-arrow {
  font-size: 20rpx;
  color: #8c6a42;
  transition: transform 0.3s;
}

.toggle-arrow.expanded {
  transform: rotate(180deg);
}

/* ---------- 阅读建议 ---------- */
.tips-section {
  background: linear-gradient(180deg, rgba(247, 240, 227, 0.85), rgba(244, 234, 216, 0.85));
}

.tip-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.tip-bullet {
  font-size: 24rpx;
  color: #8c6a42;
  line-height: 1.8;
}

.tip-text {
  font-size: 25rpx;
  line-height: 1.8;
  color: #7a6348;
}

/* ---------- 来源信息 ---------- */
.source-section {
  background: linear-gradient(180deg, rgba(247, 240, 227, 0.85), rgba(244, 234, 216, 0.85));
}

.source-content {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.source-item {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.source-label {
  font-size: 24rpx;
  color: #a08b70;
  white-space: nowrap;
}

.source-value {
  font-size: 26rpx;
  color: #5b4330;
  font-weight: 500;
}

.source-link {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 20rpx;
  background: rgba(140, 106, 66, 0.06);
  border-radius: 12rpx;
  margin-top: 4rpx;
}

.source-link:active {
  background: rgba(140, 106, 66, 0.12);
}

.source-link-icon {
  font-size: 28rpx;
}

.source-link-text {
  font-size: 25rpx;
  color: #8c6a42;
  font-weight: 500;
}

/* ---------- 相关推荐 ---------- */
.related-section {
  margin: 20rpx 24rpx;
  padding: 28rpx;
  background: #fffcf7;
}

.related-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.related-card {
  width: calc(50% - 8rpx);
  border-radius: 16rpx;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(255, 252, 247, 0.98), rgba(249, 239, 225, 0.98));
  box-shadow: 0 2rpx 10rpx rgba(140, 106, 66, 0.06);
  transition: transform 0.2s;
}

.related-card:active {
  transform: scale(0.97);
}

.related-cover {
  height: 160rpx;
  position: relative;
  overflow: hidden;
}

.related-cover-img {
  width: 100%;
  height: 100%;
}

.related-cover-placeholder {
  background: linear-gradient(135deg, #9f2d22, #d79c53);
  display: flex;
  align-items: center;
  justify-content: center;
}

.related-cover-text {
  font-size: 52rpx;
  color: rgba(255, 249, 242, 0.45);
  font-weight: 700;
}

.related-info {
  padding: 16rpx;
}

.related-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #38261a;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.related-meta {
  font-size: 21rpx;
  color: #a08b70;
  margin-top: 6rpx;
}

/* ---------- 讨论入口 ---------- */
.discuss-entry {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.discuss-entry:active {
  opacity: 0.8;
}

.discuss-icon {
  font-size: 40rpx;
}

.discuss-content {
  flex: 1;
}

.discuss-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #38261a;
}

.discuss-desc {
  font-size: 23rpx;
  color: #8a7352;
  margin-top: 4rpx;
}

.discuss-arrow {
  font-size: 36rpx;
  color: #c4a97a;
  font-weight: 300;
}

/* ---------- 底部安全区 ---------- */
.bottom-safe {
  height: env(safe-area-inset-bottom, 20rpx);
}
