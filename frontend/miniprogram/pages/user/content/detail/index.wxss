.detail-shell {
  padding: 0;
  overflow: hidden;
}

.detail-cover {
  position: relative;
  height: 360rpx;
}

.detail-cover-image {
  width: 100%;
  height: 100%;
}

.detail-cover-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(16, 10, 8, 0.08), rgba(18, 9, 6, 0.68));
}

.detail-cover-content {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 28rpx;
}

.detail-chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 245, 230, 0.18);
  color: #ffe1b7;
  font-size: 22rpx;
  margin-bottom: 14rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
  color: #2f2318;
  line-height: 1.5;
}

.title.on-cover {
  color: #fff8f2;
  margin-bottom: 10rpx;
}

.meta {
  color: #8b6741;
  margin-bottom: 20rpx;
  font-size: 25rpx;
}

.meta.on-cover {
  color: rgba(255, 242, 231, 0.86);
  margin-bottom: 0;
}

.detail-meta-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  padding: 20rpx 26rpx 0;
}

.detail-mini-chip {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #f5e7d6;
  color: #8b6139;
  font-size: 21rpx;
}

.intro-card,
.body-card,
.insight-card {
  padding: 26rpx;
}

.intro-card,
.insight-card {
  border-bottom: 1rpx solid rgba(133, 97, 63, 0.10);
}

.insight-card.soft {
  background: rgba(247, 240, 227, 0.72);
}

.insight-item {
  color: #6b513b;
  font-size: 26rpx;
  line-height: 1.8;
  margin-bottom: 10rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #38261a;
  margin-bottom: 14rpx;
}

.summary {
  color: #6f5540;
  font-size: 27rpx;
  line-height: 1.85;
}

.body {
  line-height: 1.95;
  white-space: pre-wrap;
  color: #5a4430;
  font-size: 27rpx;
}

.empty {
  color: #9f8b72;
  text-align: center;
  padding: 40rpx 0;
}
