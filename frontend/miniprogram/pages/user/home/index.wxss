/* 纯CSS封面图案（替代emoji） */
.cover-pattern {
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
}
.cover-pattern::before,
.cover-pattern::after {
  content: '';
  position: absolute;
  border-radius: 4rpx;
}
/* 内容：叠放的纸张图案 */
.cover-pattern.content::before {
  width: 60rpx; height: 70rpx;
  top: 30%; left: 50%;
  transform: translate(-60%, -50%) rotate(-6deg);
  background: rgba(140, 106, 66, 0.15);
  border: 3rpx solid rgba(140, 106, 66, 0.2);
}
.cover-pattern.content::after {
  width: 60rpx; height: 70rpx;
  top: 30%; left: 50%;
  transform: translate(-40%, -50%) rotate(3deg);
  background: rgba(140, 106, 66, 0.1);
  border: 3rpx solid rgba(140, 106, 66, 0.15);
}
/* 活动：日历/地图标记 */
.cover-pattern.event::before {
  width: 50rpx; height: 50rpx;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(159, 45, 34, 0.12);
  border-radius: 10rpx;
  border: 3rpx solid rgba(159, 45, 34, 0.18);
}
.cover-pattern.event::after {
  width: 16rpx; height: 20rpx;
  top: 28%; left: 50%;
  transform: translateX(-50%);
  background: rgba(159, 45, 34, 0.2);
  border-radius: 8rpx 8rpx 0 0;
}
/* 讨论：对话气泡 */
.cover-pattern.topic::before {
  width: 54rpx; height: 36rpx;
  top: 42%; left: 50%;
  transform: translate(-58%, -50%);
  background: rgba(99, 102, 241, 0.12);
  border-radius: 16rpx 16rpx 16rpx 4rpx;
}
.cover-pattern.topic::after {
  width: 48rpx; height: 32rpx;
  top: 58%; left: 50%;
  transform: translate(-42%, -50%);
  background: rgba(99, 102, 241, 0.08);
  border-radius: 16rpx 16rpx 4rpx 16rpx;
}

