/* CRS v2.0.8：黑塔对话气泡（脚底位置） */
.hero-mood-bubble {
  position: absolute;
  bottom: 0rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 6rpx 18rpx;
  border-radius: 16rpx 16rpx 4rpx 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  white-space: nowrap;
  animation: bubbleFadeIn 0.6s ease;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.hero-mood-bubble.mood-curious {
  background: rgba(139, 92, 246, 0.18);
  color: #7c3aed;
  border: 1rpx solid rgba(139, 92, 246, 0.2);
}

.hero-mood-bubble.mood-thinking {
  background: rgba(251, 146, 60, 0.18);
  color: #c2410c;
  border: 1rpx solid rgba(251, 146, 60, 0.2);
}

.hero-mood-bubble.mood-confident {
  background: rgba(34, 197, 94, 0.18);
  color: #15803d;
  border: 1rpx solid rgba(34, 197, 94, 0.2);
}

@keyframes bubbleFadeIn {
  from { opacity: 0; transform: translateX(-50%) translateY(-8rpx); }
  to { opacity: 1; transform: translateX(-50%) translateY(0); }
}

