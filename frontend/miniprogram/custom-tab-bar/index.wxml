<view class="tabbar-wrap">
  <view class="tabbar-shell">
    <view
      wx:for="{{list}}"
      wx:key="pagePath"
      class="tab-item {{selected === index ? 'active' : ''}}"
      data-path="{{item.pagePath}}"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <view class="tab-icon icon-{{item.key}}">
        <view class="glyph g1"></view>
        <view class="glyph g2"></view>
        <view class="glyph g3"></view>
      </view>
      <view class="tab-text">{{item.text}}</view>
    </view>
  </view>
</view>
