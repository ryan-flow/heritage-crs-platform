/* ========== 数字人组件样式 ========== */

/* 外层容器：全屏覆盖 */
.digital-human-shell {
  position: fixed;
  inset: 0;
  z-index: 9999;
  pointer-events: none;
}

/* ===== 遮罩层（展开时）===== */
.digital-human-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  z-index: 10001;
  pointer-events: auto;
}

/* ===== 展开面板（展开时）===== */
.digital-human-panel {
  position: fixed;
  right: 20rpx;
  bottom: 500rpx;
  width: 560rpx;
  max-height: 760rpx;
  border-radius: 26rpx;
  padding: 20rpx;
  background: linear-gradient(180deg, rgba(255, 252, 255, 0.98), rgba(243, 236, 255, 0.96));
  border: 1rpx solid rgba(166, 132, 236, 0.26);
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.15);
  z-index: 10002;
  pointer-events: auto;
}
.digital-human-panel-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 12rpx;
}
.digital-human-panel-title { font-size: 32rpx; font-weight: 800; color: #3f2865; letter-spacing: 2rpx; }
.digital-human-close {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 48rpx;
  min-height: 48rpx;
  font-size: 22rpx;
  color: #7d63b3;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(145, 114, 218, 0.12);
  height: fit-content;
}

/* 消息列表 */
.digital-human-message-list {
  max-height: 420rpx;
  min-height: 160rpx;
  margin-bottom: 12rpx;
}
.digital-human-msg {
  display: block;
  max-width: 88%;
  border-radius: 18rpx;
  padding: 14rpx 18rpx;
  margin-bottom: 10rpx;
  font-size: 23rpx;
  line-height: 1.8;
  word-break: break-word;
  white-space: pre-wrap;
}
.digital-human-msg.is-guide {
  background: #f3ecff;
  color: #49336f;
}
.digital-human-msg.is-user {
  margin-left: auto;
  background: linear-gradient(135deg, #9f2d22, #bf563f);
  color: #fff8f0;
  text-align: right;
}

/* 操作按钮行 */
.digital-human-actions { display: flex; justify-content: flex-end; margin-bottom: 10rpx; }
.digital-human-action-btn { min-width: 160rpx; height: 58rpx; line-height: 58rpx; border-radius: 999rpx; font-size: 21rpx; background: #efe6ff; color: #613e9e; }

/* 输入行 */
.digital-human-input-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.digital-human-input {
  flex: 1;
  height: 66rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dfcff8;
  background: #fff;
  padding: 0 20rpx;
  font-size: 24rpx;
}

/* 发送按钮：圆形（与AI页统一） */
.digital-human-send-circle {
  width: 66rpx;
  height: 66rpx;
  border-radius: 50%;
  background: #e8ddd4;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}
.digital-human-send-circle.send-active {
  background: linear-gradient(135deg, #9f2d22, #c74a3a);
  box-shadow: 0 4rpx 14rpx rgba(159, 45, 34, 0.3);
}
.send-icon {
  color: #b8a89a;
  font-size: 26rpx;
  font-weight: 700;
}
.send-active .send-icon {
  color: #fff;
}

/* ============================================================
 * 浮动按钮（FAB）
 * ============================================================ */
.digital-human-fab-wrap {
  position: fixed;
  right: 16rpx;
  bottom: 220rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10003;
  pointer-events: auto !important;
  cursor: pointer;
  padding: 12rpx 18rpx;
}

.digital-human-fab-inner {
  width: 180rpx;
  height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

/* ===== 状态卡（悬浮提示气泡）===== */
.digital-human-status-card {
  position: fixed;
  right: 160rpx;
  bottom: 300rpx;
  width: 300rpx;
  border-radius: 20rpx;
  padding: 16rpx 18rpx;
  background: linear-gradient(180deg, rgba(255, 252, 255, 0.97), rgba(245, 238, 255, 0.94));
  border: 1rpx solid rgba(145, 114, 218, 0.25);
  box-shadow: 0 12rpx 30rpx rgba(62, 41, 103, 0.15);
  z-index: 10002;
  pointer-events: auto !important;
  animation: statusCardIn .35s ease-out;
}

@keyframes statusCardIn {
  from { opacity: 0; transform: translateY(16rpx) scale(.95); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

.digital-human-status-kicker {
  font-size: 19rpx;
  color: #9476cf;
  margin-bottom: 4rpx;
  letter-spacing: 1rpx;
}
.digital-human-status-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #3d275e;
  margin-bottom: 4rpx;
}
.digital-human-status-desc {
  font-size: 21rpx;
  line-height: 1.55;
  color: #6c578c;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.scene-activity .digital-human-status-card { background: linear-gradient(180deg, rgba(255, 252, 255, 0.97), rgba(236, 246, 255, 0.94)); }
.scene-ai .digital-human-status-card { background: linear-gradient(180deg, rgba(255, 252, 255, 0.97), rgba(242, 236, 255, 0.95)); }

/* ===== 动画关键帧 ===== */
@keyframes jyFloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8rpx); } }
@keyframes orbitPulse { 0%, 100% { transform: scale(0.96); opacity: 0.9; } 50% { transform: scale(1.04); opacity: 1; } }
@keyframes sparkFloat { 0%, 100% { transform: translateY(0) scale(1); opacity: 0.65; } 50% { transform: translateY(-8rpx) scale(1.14); opacity: 1; } }
@keyframes pedestalGlow { 0%, 100% { transform: scaleX(0.96); opacity: 0.88; } 50% { transform: scaleX(1.04); opacity: 1; } }
@keyframes hatTilt { 0%, 100% { transform: rotate(0deg); } 50% { transform: rotate(-2deg); } }
@keyframes hairLeft { 0%, 100% { transform: rotate(8deg) translateY(0); } 50% { transform: rotate(12deg) translateY(4rpx); } }
@keyframes hairRight { 0%, 100% { transform: rotate(-8deg) translateY(0); } 50% { transform: rotate(-12deg) translateY(4rpx); } }
@keyframes bodyLift { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(2rpx); } }
@keyframes mouthTalk { 0%, 100% { width: 10rpx; height: 4rpx; } 50% { width: 8rpx; height: 10rpx; } }
@keyframes rightWave { 0%, 100% { transform: rotate(-16deg); } 50% { transform: rotate(-34deg); } }
