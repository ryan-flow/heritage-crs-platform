APP_ENV=production
APP_DEBUG=false
API_PREFIX=/api/v1

# PostgreSQL connection string
# Local Docker: postgresql://heritage:heritage123@postgres:5432/heritage
# Supabase:     postgresql://user:pass@host:6543/postgres
DATABASE_URL=postgresql://heritage:heritage123@postgres:5432/heritage

