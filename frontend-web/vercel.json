{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/:path+",
      "destination": "http://106.55.55.54:8001/api/:path+"
    },
    {
      "source": "/storage/:path+",
      "destination": "http://106.55.55.54:8001/storage/:path+"
    },
    {
      "source": "/static/:path+",
      "destination": "http://106.55.55.54:8001/static/:path+"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
