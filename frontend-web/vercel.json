{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "env": {
    "VITE_API_BASE": "/api/v1"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://106.55.55.54:8001/api/:path*"
    },
    {
      "source": "/storage/:path*",
      "destination": "http://106.55.55.54:8001/storage/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "http://106.55.55.54:8001/static/:path*"
    }
  ]
}