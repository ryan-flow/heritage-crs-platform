        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;graph TB\n    %% 实体（矩形）\n    User[\&quot;用户表\&quot;]\n    Content[\&quot;内容表\&quot;]\n    Activity[\&quot;活动表\&quot;]\n    Topic[\&quot;讨论话题\&quot;]\n    RecLog[\&quot;推荐日志\&quot;]\n    QAlog[\&quot;AI问答记录\&quot;]\n    CrsSession[\&quot;CRS会话\&quot;]\n\n    %% 关系（菱形）\n    R1{{\&quot;收藏\&quot;}}\n    R2{{\&quot;报名\&quot;}}\n    R3{{\&quot;发帖\&quot;}}\n    R4{{\&quot;评论\&quot;}}\n    R5{{\&quot;点赞\&quot;}}\n    R6{{\&quot;收藏\&quot;}}\n    R7{{\&quot;行为\&quot;}}\n    R8{{\&quot;提问\&quot;}}\n    R9{{\&quot;参与\&quot;}}\n\n    %% 用户属性（椭圆）\n    U_id((id))\n    U_openid((openid))\n    U_role((role))\n    U_conf((置信度))\n\n    %% 内容属性\n    C_id((id))\n    C_title((标题))\n    C_quality((质量分))\n\n    %% 活动属性\n    A_id((id))\n    A_title((标题))\n\n    %% 讨论属性\n    T_id((id))\n    T_title((标题))\n\n    %% 推荐日志属性\n    RL_id((id))\n    RL_action((行为类型))\n\n    %% AI问答属性\n    Q_id((id))\n    Q_source((来源))\n\n    %% CRS会话属性\n    CS_id((id))\n    CS_mode((模式))\n\n    %% 实体-属性连线\n    User --- U_id &amp; U_openid &amp; U_role &amp; U_conf\n    Content --- C_id &amp; C_title &amp; C_quality\n    Activity --- A_id &amp; A_title\n    Topic --- T_id &amp; T_title\n    RecLog --- RL_id &amp; RL_action\n    QAlog --- Q_id &amp; Q_source\n    CrsSession --- CS_id &amp; CS_mode\n\n    %% 实体-关系-实体 连线（带基数）\n    User --|\&quot;M\&quot;| R1 --|\&quot;N\&quot;| Content\n    User --|\&quot;M\&quot;| R2 --|\&quot;N\&quot;| Activity\n    User --|\&quot;M\&quot;| R3 --|\&quot;1\&quot;| Topic\n    User --|\&quot;M\&quot;| R4 --|\&quot;N\&quot;| Topic\n    User --|\&quot;M\&quot;| R5 --|\&quot;N\&quot;| Topic\n    User --|\&quot;M\&quot;| R6 --|\&quot;N\&quot;| Topic\n    User --|\&quot;1\&quot;| R7 --|\&quot;M\&quot;| RecLog\n    User --|\&quot;1\&quot;| R8 --|\&quot;M\&quot;| QAlog\n    User --|\&quot;1\&quot;| R9 --|\&quot;1\&quot;| CrsSession\n\n    classDef entity fill:#fff,stroke:#333,stroke-width:2px\n    classDef relation fill:#fff,stroke:#333,stroke-width:1.5px\n    classDef attr fill:#f0f0f0,stroke:#666,stroke-width:1px\n\n    class User,Content,Activity,Topic,RecLog,QAlog,CrsSession entity\n    class R1,R2,R3,R4,R5,R6,R7,R8,R9 relation\n    class U_id,U_openid,U_role,U_conf,C_id,C_title,C_quality,A_id,A_title,T_id,T_title,RL_id,RL_action,Q_id,Q_source,CS_id,CS_mode attr&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="NTvGBuVJ8s5KA4meMBlB-633">
